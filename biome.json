{
        "$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
        "vcs": {
                "enabled": true,
                "clientKind": "git",
                "useIgnoreFile": true,
                "defaultBranch": "main"
        },
        "files": {
                "ignoreUnknown": false
        },
        "formatter": {
                "enabled": true,
                "indentStyle": "space",
                "attributePosition": "multiline",
                "bracketSameLine": true,
                "bracketSpacing": true,
                "expand": "auto",
                "formatWithErrors": true,
                "indentWidth": 8,
                "lineEnding": "lf",
                "lineWidth": 80
        },
        "linter": {
                "enabled": true,
                "rules": {
                        "recommended": true,
                        "complexity": {
                                "noExcessiveCognitiveComplexity": "warn",
                                "noExcessiveLinesPerFunction": "warn",
                                "noExcessiveNestedTestSuites": "error",
                                "noForEach": "error",
                                "noImplicitCoercions": "info",
                                "noUselessStringConcat": "warn",
                                "noVoid": "error",
                                "useSimplifiedLogicExpression": "warn",
                                "useWhile": "warn"
                        },
                        "correctness": {
                                "noGlobalDirnameFilename": "error",
                                "noProcessGlobal": "error",
                                "noUndeclaredVariables": "error",
                                "useImportExtensions": "error",
                                "useJsonImportAttributes": "error",
                                "useSingleJsDocAsterisk": "info"
                        },
                        "nursery": {
                                "useMaxParams": "error"
                        },
                        "performance": {
                                "noAwaitInLoops": "error",
                                "noBarrelFile": "error",
                                "noDelete": "error",
                                "noNamespaceImport": "error",
                                "noReExportAll": "error"
                        },
                        "style": {
                                "noCommonJs": "error",
                                "noExportedImports": "error",
                                "noNegationElse": "error",
                                "noNestedTernary": "warn",
                                "noParameterAssign": "error",
                                "noRestrictedGlobals": {
                                        "level": "error",
                                        "options": {
                                                "deniedGlobals": {
                                                        "error": "Do not use the global error identifier.",
                                                        "event": "Do not use the global event identifier."
                                                }
                                        }
                                },
                                "noSubstr": "error",
                                "noUselessElse": "error",
                                "noYodaExpression": "error",
                                "useAtIndex": "error",
                                "useBlockStatements": "error",
                                "useCollapsedElseIf": "error",
                                "useCollapsedIf": "error",
                                "useConsistentBuiltinInstantiation": "error",
                                "useConsistentObjectDefinitions": "error",
                                "useDefaultParameterLast": "error",
                                "useDefaultSwitchClause": "warn",
                                "useExportsLast": "error",
                                "useForOf": "error",
                                "useGroupedAccessorPairs": "error",
                                "useNodeAssertStrict": "error",
                                "useNumberNamespace": "error",
                                "useNumericSeparators": "error",
                                "useObjectSpread": "error",
                                "useShorthandAssign": "error",
                                "useSingleVarDeclarator": "error",
                                "useSymbolDescription": "error",
                                "useThrowNewError": "error",
                                "useThrowOnlyError": "error",
                                "useTrimStartEnd": "error"
                        },
                        "suspicious": {
                                "noAlert": "error",
                                "noConsole": {
                                        "level": "warn",
                                        "options": {
                                                "allow": [
                                                        "error",
                                                        "info",
                                                        "warn"
                                                ]
                                        }
                                },
                                "noConstantBinaryExpressions": "error",
                                "noDuplicateTestHooks": "error",
                                "noEmptyBlockStatements": "error",
                                "noExportsInTest": "error",
                                "noFocusedTests": "error",
                                "noMisplacedAssertion": "error",
                                "noSkippedTests": "info",
                                "noUnassignedVariables": "error",
                                "noVar": "error",
                                "useAwait": "error",
                                "useErrorMessage": "error",
                                "useGuardForIn": "error",
                                "useNumberToFixedDigitsArgument": "error",
                                "useStaticResponseMethods": "error"
                        }
                }
        },
        "javascript": {
                "formatter": {
                        "quoteStyle": "single",
                        "enabled": true,
                        "arrowParentheses": "always",
                        "jsxQuoteStyle": "single",
                        "operatorLinebreak": "after",
                        "quoteProperties": "asNeeded",
                        "semicolons": "always",
                        "trailingCommas": "all"
                }
        },
        "assist": {
                "enabled": true,
                "actions": {
                        "source": {
                                "organizeImports": "on"
                        }
                }
        },
        "html": {
                "formatter": {
                        "enabled": true,
                        "selfCloseVoidElements": "always",
                        "whitespaceSensitivity": "css"
                }
        },
        "css": {
                "formatter": {
                        "enabled": true,
                        "quoteStyle": "single"
                }
        },
        "json": {
                "formatter": {
                        "enabled": true,
                        "trailingCommas": "none"
                }
        }
}
